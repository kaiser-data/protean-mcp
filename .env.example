# Chameleon MCP — API Keys Reference
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env and fill in the keys you have.
# Chameleon re-reads .env on every morph/call — no restart needed after adding a key.
# ~/.env and ~/.chameleon/.env are also checked (project .env wins).
#
# No-key servers (work out of the box):
#   open-meteo-mcp-server  — weather forecasts (no key)
#   yahoo-finance-mcp      — stock quotes and financials (no key)
#   @modelcontextprotocol/server-filesystem — local files (no key, needs --allowed-dirs)
#   @modelcontextprotocol/server-git        — git operations (no key)
# ─────────────────────────────────────────────────────────────────────────────


# ── Chameleon hub ─────────────────────────────────────────────────────────────
# Unlocks 3,000+ Smithery-verified servers in search() results.
# Without this, Chameleon still works via npm, official, Glama, GitHub registries.
# Free key: https://smithery.ai/account/api-keys
SMITHERY_API_KEY=


# ── Web search ────────────────────────────────────────────────────────────────
# Compare these side-by-side with lean morph — each has a different strength.
#
# Brave Search — 2 tools, ~300 tokens
#   brave_web_search(query, count)  brave_local_search(query, location)
#   Free: 2,000 queries/month — https://brave.com/search/api/
BRAVE_API_KEY=

# Exa — 3 tools, ~993 tokens
#   web_search_exa  crawling_exa  get_code_context_exa
#   Best for: AI-native search + full page content + code examples
#   Free tier: https://exa.ai
EXA_API_KEY=

# Linkup — 1 tool, ~150 tokens (leanest option)
#   linkup_search(query, depth, output_type)
#   Best for: source-backed answers with citations
#   Free tier: https://linkup.so
LINKUP_API_KEY=

# Parallel Search — high-accuracy search
#   Free tier: https://www.parallel.ai
PARALLEL_API_KEY=


# ── Web scraping & crawling ───────────────────────────────────────────────────
# Firecrawl — ~9 tools (~1,800 tokens full / ~400 tokens lean)
#   scrape  crawl  search  map  extract  deep_research  generate_llmstxt
#   Use lean morph: morph("firecrawl-mcp", tools=["scrape", "search"])
#   Free: 500 credits — https://firecrawl.dev
FIRECRAWL_API_KEY=

# ScrapeGraph AI — 3 tools (~600 tokens)
#   smartscraper  markdownify  searchscraper
#   Best for: AI-powered structured data extraction from any URL
#   Free tier: https://scrapegraphai.com
SGAI_API_KEY=


# ── Code & version control ────────────────────────────────────────────────────
# GitHub — 26 tools (~4,200 tokens full / ~500 tokens lean)
#   Repos, issues, PRs, branches, code search, file contents
#   Lean example: morph("@modelcontextprotocol/server-github", tools=["search_repositories","create_issue","get_file_contents"])
#   Fine-grained token (repo + issues + pull_requests):
#   https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=


# ── Productivity & workspace ──────────────────────────────────────────────────
# Notion — official server has ~30 tools (heavy — use lean morph)
#   morph("@notionhq/notion-mcp-server", tools=["notion_search","notion_retrieve_page","notion_create_page"])
#   Lightweight alternative: @shck-dev/notion-mcp (3 tools, browser cookie only)
#   Create key: https://notion.so/my-integrations
NOTION_API_KEY=

# Linear — issue and project management
#   ~20 tools: create/update issues, list projects, manage cycles
#   Create key: https://linear.app/settings/api
LINEAR_API_KEY=

# Slack — channel messaging, search, file access
#   Create bot token (channels:read, chat:write, search:read scopes):
#   https://api.slack.com/apps
SLACK_BOT_TOKEN=


# ── Google services ───────────────────────────────────────────────────────────
# Google Maps — geocoding, directions, places search
#   morph("google_maps")
#   Free tier (generous): https://console.cloud.google.com → Maps JavaScript API
GOOGLE_MAPS_API_KEY=

# Google Calendar / Gmail — via Smithery (oauth-based, configured in Smithery)
#   morph("googlecalendar")  morph("gmail")
#   OAuth setup: https://smithery.ai


# ── Memory & persistence ──────────────────────────────────────────────────────
# Mem0 — save/search memories across sessions and users
#   morph("mem0ai/mem0-memory-mcp")
#   Free tier: https://app.mem0.ai/dashboard/api-keys
MEM0_API_KEY=


# ── AI & model APIs ───────────────────────────────────────────────────────────
# Anthropic — for MCP servers that call Claude internally
ANTHROPIC_API_KEY=

# OpenAI — for MCP servers that use GPT or DALL-E
OPENAI_API_KEY=


# ── Database & backend ────────────────────────────────────────────────────────
# Supabase — query your Supabase project
#   https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
